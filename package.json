{
  "name": "ts-checker-rspack-plugin",
  "version": "1.5.1",
  "description": "Runs typescript type checker and linter on separate process.",
  "keywords": [
    "rspack",
    "plugin",
    "typescript",
    "typecheck"
  ],
  "bugs": {
    "url": "https://github.com/rstackjs/ts-checker-rspack-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rstackjs/ts-checker-rspack-plugin.git"
  },
  "homepage": "https://github.com/rstackjs/ts-checker-rspack-plugin#readme",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rslib",
    "bump": "npx bumpp",
    "dev": "rslib -w",
    "lint": "rslint",
    "lint:write": "rslint --fix",
    "precommit": "pnpm build && pnpm test:unit",
    "prepare": "husky",
    "test": "pnpm build && pnpm test:unit && pnpm test:e2e",
    "test:e2e": "cd test/e2e && pnpm test",
    "test:e2e:setup": "cd test/e2e && pnpm run setup",
    "test:unit": "rstest --config=test/unit/rstest.config.ts"
  },
  "dependencies": {
    "@rspack/lite-tapable": "^1.1.2",
    "chokidar": "^3.6.0",
    "memfs": "^4.57.8",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@babel/code-frame": "^7.29.7",
    "@rslib/core": "^0.23.1",
    "@rslint/core": "^0.6.4",
    "@rspack/core": "^2.1.2",
    "@rstest/core": "^0.10.6",
    "@types/babel__code-frame": "^7.27.0",
    "@types/is-glob": "^4.0.4",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "is-glob": "^4.0.3",
    "minimatch": "^10.2.5",
    "mock-fs": "^5.5.0",
    "prettier": "^3.9.4",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@rspack/core": "^1.0.0 || ^2.0.0",
    "@typescript/native-preview": "^7.0.0-0",
    "typescript": ">=3.8.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    },
    "@typescript/native-preview": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
